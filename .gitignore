# Godot 4 .NET
.godot/
/export/
/build/
*.translation

# .NET / MSBuild build output
bin/
obj/
.mono/
*.user
*.userprefs

# IDE
.vs/
.idea/
*.suo
*.csproj.user

# OS junk
.DS_Store
Thumbs.db

# Mono crash logs
mono_crash.*.json
mono_crash.*.dmp

# mruby-ext native gem build inputs/outputs (per mruby-ext/AGENTS.md:
# lib/, build/, .xmake/ are gitignored; host .lib/.so/.dylib are prebuilt,
# not produced here). Keep vendored SOURCE (.c/.h/config.h/export.def/xmake.lua).
mruby-ext/**/lib/
mruby-ext/**/build/
mruby-ext/**/build_x64/
mruby-ext/**/.xmake/
mruby-ext/**/.cache/
mruby-ext/**/*.o
mruby-ext/**/*.obj
mruby-ext/**/*.lib
mruby-ext/**/*.dll
mruby-ext/**/*.so
mruby-ext/**/*.dylib
mruby-ext/**/*.a
mruby-ext/**/*.exp
mruby-ext/**/*.pdb

# Godot UID sidecars for vendored DotZLib C# (excluded from compile in
# RGSS-Godot.csproj, so these are editor-generated noise, not project assets).
mruby-ext/**/*.cs.uid

# Decompiled RMVA game scripts (local debug aid produced by tools/extract_scripts.py
# from the copyrighted Scripts.rvdata2). Game content is not tracked here, same as
# RMProject/ and *.rvdata2 — regenerate locally instead of committing.
docs/rmva-scripts/
